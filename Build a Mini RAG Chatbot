from groq import Groq
import chromadb
import json

client = Groq()

# --- Setup: Knowledge base ---
chroma_client = chromadb.Client()
kb = chroma_client.create_collection("chatbot_kb")

docs = [
    "Project Alpha deadline is March 15, 2025. Lead: Sarah Chen. Budget: $75,000.",
    "Project Beta launched Jan 10, 2025. Budget: $50,000. Status: completed.",
    "Engineering team meets every Tuesday at 10am in Room 4B or Zoom.",
    "To request time off, submit a form in HR portal 2 weeks in advance.",
    "CI/CD pipeline uses GitHub Actions. Deploys to staging on merge to main.",
    "Production database is PostgreSQL 15 on AWS RDS. Read replicas in us-west-2.",
    "Code reviews require 2 approvals before merging. Use conventional commits.",
    "New employees get a $2,500 laptop budget. Orientation is the first Monday.",
]
kb.add(documents=docs, ids=[f"doc_{i}" for i in range(len(docs))])

# --- The chatbot ---
class MiniRAGChatbot:
    def __init__(self):
        self.conversation = []
        self.system = """You are a helpful company assistant. You have access to a knowledge base.

When answering questions about company topics (projects, processes, policies):
- Use the provided context to give accurate answers
- If the context doesn't contain the answer, say "I don't have that information"
- Be specific and cite details from the context

For general questions, answer from your own knowledge."""

    def _retrieve_context(self, query):
        """Search the knowledge base for relevant documents."""
        results = kb.query(query_texts=[query], n_results=3)
        return results["documents"][0]

    def chat(self, user_input):
        print(f"\nYou: {user_input}")

        # Retrieve relevant context
        context_docs = self._retrieve_context(user_input)
        context = "\n".join(f"- {doc}" for doc in context_docs)

        # Build messages with conversation history + context
        self.conversation.append({
            "role": "user",
            "content": f"[Retrieved context]\n{context}\n\n[User question]\n{user_input}"
        })

        messages = [
            {"role": "system", "content": self.system},
            *self.conversation[-10:]  # Keep last 10 messages (sliding window)
        ]

        response = client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            max_tokens=400,
            temperature=0,
            messages=messages,
        )

        reply = response.choices[0].message.content
        self.conversation.append({"role": "assistant", "content": reply})

        print(f"Bot: {reply}\n")
        return reply

# --- Test it! ---
bot = MiniRAGChatbot()

bot.chat("When is Project Alpha due?")
bot.chat("Who's leading it?")  # Should remember context from previous answer
bot.chat("What about Project Beta?")
bot.chat("When does the engineering team meet?")
bot.chat("What's the process for code reviews?")
bot.chat("What's the company stock price?")  # Should say "I don't know"
bot.chat("What was my first question?")  # Memory test!
```

