### Step 2: Build the Sliding Window Manager

```python
from groq import Groq

client = Groq()

def count_tokens_approx(text):
    """Rough token count: ~4 characters per token for English."""
    return len(text) // 4

class ConversationManager:
    def __init__(self, max_tokens=2000):
        self.messages = []
        self.max_tokens = max_tokens

    def _total_tokens(self):
        return sum(count_tokens_approx(m["content"]) for m in self.messages)

    def _trim(self):
        """Drop oldest messages to stay under limit."""
        trimmed = 0
        while self._total_tokens() > self.max_tokens and len(self.messages) > 2:
            self.messages.pop(0)
            trimmed += 1
        if trimmed:
            print(f"  [Trimmed {trimmed} old messages]")

    def chat(self, user_input):
        self.messages.append({"role": "user", "content": user_input})
        self._trim()

        response = client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            max_tokens=300,
            messages=[
                {"role": "system", "content": "You are a helpful assistant. Be concise."},
                *self.messages
            ]
        )

        reply = response.choices[0].message.content
        self.messages.append({"role": "assistant", "content": reply})

        tokens = self._total_tokens()
        print(f"  [Context: ~{tokens}/{self.max_tokens} tokens, {len(self.messages)} msgs]")
        print(f"Assistant: {reply}\n")
        return reply

# --- Test: have a long conversation ---
convo = ConversationManager(max_tokens=2000)

topics = [
    "Tell me about the history of coffee in 2-3 sentences.",
    "What about tea? Same format.",
    "Which one has more caffeine?",
    "Now tell me about chocolate's history.",
    "How is chocolate made from cacao beans?",
    "What's the connection between coffee, tea, and chocolate?",
    "Do you remember what I first asked you about?",  # Memory test!
]

for topic in topics:
    print(f"You: {topic}")
    convo.chat(topic)
```

### Step 3: Build the Summarization Strategy

```python
class SummarizingManager:
    def __init__(self, max_tokens=2000, keep_recent=4):
        self.messages = []
        self.max_tokens = max_tokens
        self.keep_recent = keep_recent

    def _total_tokens(self):
        return sum(count_tokens_approx(m["content"]) for m in self.messages)

    def _summarize_old(self):
        if len(self.messages) <= self.keep_recent + 2:
            return
        if self._total_tokens() <= self.max_tokens:
            return

        old = self.messages[:-self.keep_recent]
        recent = self.messages[-self.keep_recent:]

        old_text = "\n".join(f"{m['role'].upper()}: {m['content'][:200]}" for m in old)

        summary_resp = client.chat.completions.create(
            model="llama-3.1-8b-instant",  # Use cheap model for summarization
            max_tokens=150,
            messages=[{"role": "user", "content": f"Summarize this conversation in 2-3 sentences, preserving key facts:\n\n{old_text}"}]
        )

        summary = summary_resp.choices[0].message.content
        print(f"  [Summarized {len(old)} old messages]")

        self.messages = [
            {"role": "user", "content": f"[Previous conversation summary: {summary}]"},
            {"role": "assistant", "content": "Got it, I'll keep that context in mind."},
            *recent
        ]

    def chat(self, user_input):
        self.messages.append({"role": "user", "content": user_input})
        self._summarize_old()

        response = client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            max_tokens=300,
            messages=[
                {"role": "system", "content": "You are a helpful assistant. Be concise."},
                *self.messages
            ]
        )

        reply = response.choices[0].message.content
        self.messages.append({"role": "assistant", "content": reply})

        tokens = self._total_tokens()
        print(f"  [Context: ~{tokens}/{self.max_tokens} tokens, {len(self.messages)} msgs]")
        print(f"Assistant: {reply}\n")
        return reply

# --- Compare: same conversation, different strategy ---
convo2 = SummarizingManager(max_tokens=2000)
for topic in topics:
    print(f"You: {topic}")
    convo2.chat(topic)
```

### Step 4: Compare

On the last question ("Do you remember what I first asked?"):
- **Sliding window** likely forgot (messages were dropped)
- **Summarization** likely remembers (summary preserved key facts)

